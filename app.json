{
  "expo": {
    "name": "Ateş AR",
    "slug": "ates-ar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "ates-ar",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.atesapp.ar",
      "infoPlist": {
        "NSCameraUsageDescription": "Ateş AR deneyimi için kamera erişimi gereklidir.",
        "NSMicrophoneUsageDescription": "Sesli cevap verebilmek için mikrofon erişimi gereklidir."
      }
    },
    "android": {
      "package": "com.atesapp.ar",
      "adaptiveIcon": {
        "backgroundColor": "#FF6B35",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Ateş AR deneyimi için kamera erişimi gereklidir."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Sesli cevap verebilmek için mikrofon erişimi gereklidir."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png"
        }
      ]
    ],
    "extra": {
      "EXPO_PUBLIC_APP_ENV": "development",
      "eas": {
        "projectId": "a865746c-5672-4cbc-a3d6-1f10043fa14f"
      },
      "router": {}
    }
  }
}
